#!/bin/bash
# ==============================================================================
# NEKO VOID: SCRIPT DE INICIALIZACIÓN POST-INSTALACIÓN
# ==============================================================================

MARKER_FILE="$HOME/.rices.set"

runn(){
    echo "Iniciando configuración final de Neko Void..."
    
    # 0. Seguro de carga de entorno Wayland (CRÍTICO)
    sleep 2 
    export WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}"
    export XDG_CURRENT_DESKTOP=sway

    # 1. Crear las carpetas de usuario
    xdg-user-dirs-update && xdg-user-dirs-update --force

    # 2. Forzar Tema Oscuro en GTK
    gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
    gsettings set org.gnome.desktop.interface gtk-theme 'Adwaita-dark'
    gsettings set org.gnome.desktop.interface cursor-theme 'Adwaita'

    # 3. Disparar Matugen (Motor de color dinámico)
    if command -v matugen &> /dev/null; then
        echo "Generando paleta de colores con Matugen..."
        matugen -c "$HOME/.config/matugen/config.toml" image "/usr/share/backgrounds/edernity.png" --mode dark --source-color-index 0 || true
        killall -SIGUSR2 waybar 2>/dev/null || true
    fi

    # 4. Lanzar Neko Store / Wizard
    if [ -f "/usr/lib/Neko-Wizard/neko-store" ]; then
        /usr/lib/Neko-Wizard/neko-store &
    fi

    touch "$MARKER_FILE"
    echo "✓ Entorno SwayFX configurado exitosamente."
}

if [ -f "$MARKER_FILE" ]; then
    echo "✓ La configuración ya fue aplicada."
else 
    runn
fi
